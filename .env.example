# ============================================================
#  SHASEA — Environment Variables
#  Copy file ini, rename jadi .env, isi sesuai kebutuhan
#  Di Railway: set via Settings → Variables
# ============================================================

# ── Database (Railway MySQL) ──────────────────────────────────
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=6543
DB_NAME=railway
DB_USER=root
DB_PASS=your-railway-mysql-password

# ── App ───────────────────────────────────────────────────────
APP_URL=https://shasea.yourdomain.com
APP_ENV=production

# ── Optional: Railway auto-provides these ────────────────────
# RAILWAY_STATIC_URL=
# RAILWAY_GIT_COMMIT_SHA=
